{
  "name": "vuepill",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs=require('fs');const src='dist/assets/style.css';const dest='dist/assets/assets/style.css';if(fs.existsSync(src)){fs.mkdirSync('dist/assets/assets',{recursive:true});fs.copyFileSync(src,dest);}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "3.3.4",
    "vuetify": "3.3.15"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "1.3.3",
    "@vitejs/plugin-vue": "4.2.3",
    "sass": "1.66.1",
    "vite": "4.4.9"
  }
}
